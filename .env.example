# App
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME="JNV Smart Connect"

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/jnv-smart-connect

# JWT
JWT_ACCESS_SECRET=replace-with-a-32-byte-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-32-byte-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password reset
PASSWORD_RESET_TOKEN_EXPIRES_MIN=30

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASSWORD=replace-me
SMTP_FROM="JNV Smart Connect <no-reply@jnvsmartconnect.in>"

# Cloudinary (future ready for photo uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed script (initial Super Admin)
SEED_SUPER_ADMIN_EMAIL=superadmin@jnvsmartconnect.in
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
